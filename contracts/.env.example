# pGOLD Protocol — 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ── 部署账户 ──
PRIVATE_KEY=0x_your_private_key_here

# ── Arbitrum One 主网 RPC ──
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc

# ── Arbitrum Sepolia 测试网 RPC ──
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# ── 合约验证 (Arbiscan) ──
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# ── 外部合约地址 (Arbitrum One) ──
# USDC (Arbitrum 已验证): 0xaf88d065e77c8cC2239327C5EDb3A432268e5831
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# PAXG on Arbitrum One (部署前需确认实际地址)
# 测试网(arbitrum-sepolia)：deploy_testnet.js 自动部署 ERC20Mock18，无需配置此项
PAXG_ADDRESS=0x_

# Uniswap V3 Router (Arbitrum 已验证): 0xE592427A0AEce92De3Edee1F18E0157C05861564
# 测试网：deploy_testnet.js 自动部署 MockUniswapRouter，无需配置此项
UNISWAP_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564

# Chainlink XAU/USD Price Feed — Arbitrum One 主网: 0x1F954Dc24a49708C26E0C1777f16750B5C6d5a2c
# 测试网：deploy_testnet.js 自动部署 MockChainlinkAggregator，无需配置此项
CHAINLINK_XAU_USD=0x_

# Chainlink PAXG/USD Price Feed — Arbitrum One 主网暂无官方 Feed，使用两步模式：PAXG/ETH × ETH/USD
# 测试网：deploy_testnet.js 自动部署 MockChainlinkAggregator，无需配置此项
CHAINLINK_PAXG_USD=0x_

# 两步模式 feeds（主网部署时调用 setTwoStepPAXGFeeds 配置）
# PAXG/ETH — Arbitrum One 主网: 0x2BAe491B065032a76Be1dB9e9eCf5738aFae203E
CHAINLINK_PAXG_ETH=0x_
# ETH/USD  — Arbitrum One 主网: 0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612
CHAINLINK_ETH_USD=0x_

# ── 测试网部署（arbitrum-sepolia）──
# 只需设置 PRIVATE_KEY，其余外部依赖由 deploy_testnet.js 自动部署 Mock 合约
# 获取测试 ETH: https://faucets.chain.link/arbitrum-sepolia
# 用法: npx hardhat run scripts/deploy_testnet.js --network arbitrum-sepolia
